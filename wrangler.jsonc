{
  "name": "mantra-japacounter",
  "compatibility_date": "2026-04-07",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "mantra.toolspoon.com/japacounter*",
      "zone_name": "toolspoon.com"
    }
  ],
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash"
  }
}
